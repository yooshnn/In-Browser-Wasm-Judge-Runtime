{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": ["^build", "^typecheck"],
      "outputs": []
    },
    "test:browser": {
      "dependsOn": ["build", "^build", "^typecheck"],
      "outputs": []
    }
  }
}
